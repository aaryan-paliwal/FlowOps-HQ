# ===========================================
# FlowOps Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# --- Server ---
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://flowops:flowops_secret@localhost:5432/flowops_db

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Authentication ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# --- Security ---
CORS_ORIGIN=http://localhost:5173
BODY_SIZE_LIMIT=10kb

# --- Sentry (Optional) ---
SENTRY_DSN=

# --- Logging ---
LOG_LEVEL=info

# --- OpenAI Integration (Codex Prompt Optimizer) ---
OPENAI_API_KEY=

