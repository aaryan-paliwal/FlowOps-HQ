# ═══════════════════════════════════════════════
# FlowOps .gitignore
# ═══════════════════════════════════════════════

# Dependencies
node_modules/

# Environment (NEVER commit secrets)
.env
.env.local
.env.*.local

# Build output
dist/
build/
.next/

# Prisma
backend/prisma/migrations/**/migration_lock.toml

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# IDE / Editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Docker volumes (local data)
docker/volumes/

# Coverage & Testing
coverage/
.nyc_output/

# Temp files
tmp/
.tmp/
scratch/

# Developer notes (internal)
dev_docs/*

# Hackathon prep files (internal)
OpenAI Hackathon/

# Package manager locks (keep package-lock.json)
yarn.lock
pnpm-lock.yaml

# Gemini / AI assistant cache
.gemini/