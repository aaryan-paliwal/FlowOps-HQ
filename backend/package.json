        "ioredis": "^5.4.2",
        "js-tiktoken": "^1.0.21",
        "jsonwebtoken": "^9.0.2",
        "postgres": "^3.4.9",
        "tiktoken": "^1.0.22",
        "uuid": "^11.1.0",
        "winston": "^3.17.0",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
